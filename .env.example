# Скопируйте в .env и заполните значения:
#   copy .env.example .env          (Windows)
#   cp .env.example .env            (Linux/macOS)
#
# Секреты хранятся только здесь (или в env на сервере), не в MySQL.
# Имена переменных для провайдеров заданы в таблице llm_providers.shared_api_key_env.

# --- База _llm_connector (test dashboard, миграции) ---

LLM_DB_HOST=100.75.41.14
LLM_DB_USER=root
LLM_DB_PASSWORD=
LLM_DB_DATABASE=_llm_connector

# Опционально: таймаут подключения к MySQL (секунды)
# LLM_DB_CONNECT_TIMEOUT=10

# Fallback, если LLM_DB_* не заданы (часто в проекте-потребителе, напр. ailenta_parser)
# DB_HOST=
# DB_USER=
# DB_PASSWORD=

# --- Ключи LLM-провайдеров (заполните только используемые) ---

API_OPENROUTER_KEY=
API_VSEGPT_KEY=
API_ARTEMOX_KEY=
API_OPENAI_KEY=
API_ROUTERAI_KEY=
API_REPLICATE_KEY=

# --- Опционально ---

# Метка в llm_request_logs (по умолчанию internal; test dashboard ставит test_dashboard)
# LLM_DEPLOYMENT_CODE=internal

# Фаза 2 (external VPS): auto | normal | degraded | offline
# LLM_DB_MODE=normal
